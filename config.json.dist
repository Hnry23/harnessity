{
    "model": {
        "provider": "ollama",
        "host": "http://192.168.1.95:11434",
        "name": "gemma4:custom",
        "headers": {
            "x-some-header": "some-value"
        }
    },
    "agent": {
        "show_thinking": true,
        "max_messages": 20,
        "max_loop_iterations": 15,
        "show_consumption": true
    },
    "tools": {
        "show_usage": true,
        "websearch_max_results": 5,
        "exec": {
            "allowed": [],
            "disallowed": []
        }
    },
    "mcp": {
        "show_usage": true,
        "servers": [
            {
                "name": "rag",
                "host": "http://localhost:7777/sse",
                "api_key": ""
            },
            {
                "name": "atlassian",
                "host": "https://mcp.atlassian.com/v1/sse",
                "api_key": "your-api-key"
            }
        ]
    }
}